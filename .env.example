# Discord Bot 設定
BOT_TOKEN=你的Bot_Token貼這裡

# Discord 應用程式資訊
CLIENT_ID=你的應用程式ID
CLIENT_SECRET=你的用戶端密鑰
PUBLIC_KEY=你的公開金鑰

# 伺服器 ID（測試用）
GUILD_ID=

# 日誌頻道（選填，不填則不發日誌）
LOG_CHANNEL_ID=

# ── 翻譯功能 ──
# OpenRouter API Key（系統翻譯引擎，三層免費模型自動切換）
# 取得：https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DeepL API Key（最終兜底，所有 OpenRouter 模型皆失敗時使用）
# 取得：https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ── 加密金鑰（保護使用者 API Key）──
# 64 hex chars (32 bytes)。建議用 `openssl rand -hex 32` 產生。
# 留空則自動產生並寫入 data/.encryption-key（請務必備份此檔）
TFD_ENCRYPTION_KEY=
