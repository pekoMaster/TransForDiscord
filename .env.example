# Discord Bot 設定
BOT_TOKEN=你的Bot_Token貼這裡

# Discord 應用程式資訊
CLIENT_ID=你的應用程式ID
CLIENT_SECRET=你的用戶端密鑰
PUBLIC_KEY=你的公開金鑰

# 伺服器 ID（測試用）
GUILD_ID=

# 日誌頻道（選填，不填則不發日誌）
LOG_CHANNEL_ID=

# ── 翻譯功能 ──
# DeepL API Key（Twitter 翻譯預設引擎，免費版每月 50 萬字）
# 取得：https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Gemini API Keys（用戶未設定個人 Key 時的系統備用，選填）
# 取得：https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY_1=
GOOGLE_GEMINI_API_KEY_2=

# ── 平台登入（選填）──
IWARA_USERNAME=
IWARA_PASSWORD=
